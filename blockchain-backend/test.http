@baseUrl = http://localhost:3000
@api = {{baseUrl}}/api/v1

### Health Check (GET)
GET {{api}}/
Accept: application/json

### Health Check (HEAD)
HEAD {{api}}/

### Method Not Allowed Example (PUT on root)
PUT {{api}}/
Content-Type: application/json

{
	"note": "Expected to fail because no PUT route is defined for /api/v1/"
}

### Start Peer Node - Org1 (POST)
POST {{api}}/fabric/peer/start
Content-Type: application/json

{
	"organization": "org1"
}

### Start Peer Node - Org2 (POST)
POST {{api}}/fabric/peer/start
Content-Type: application/json

{
	"organization": "org2"
}

### Start Peer Node - Default Org (POST with empty body)
POST {{api}}/fabric/peer/start
Content-Type: application/json

{}

### Provision Organization (POST)
POST {{api}}/fabric/org/provision
Content-Type: application/json

{
	"organizationName": "Acme Logistics",
	"adminEmail": "admin@acme.io",
	"domain": "acme.linaw.example.com",
	"channelName": "mychannel"
}

### Provision Organization - Duplicate Name (POST, expected 409 after previous call)
POST {{api}}/fabric/org/provision
Content-Type: application/json

{
	"organizationName": "Acme Logistics",
	"adminEmail": "admin2@acme.io"
}

### Provision Organization - Validation Error (POST, expected 400)
POST {{api}}/fabric/org/provision
Content-Type: application/json

{
	"organizationName": "",
	"adminEmail": "invalid-email"
}

### Execute Command In Allowed Container (POST)
POST {{api}}/fabric/container/exec
Content-Type: application/json

{
	"containerName": "cli",
	"command": "peer version"
}

### Execute Command - Missing command (POST, expected 400)
POST {{api}}/fabric/container/exec
Content-Type: application/json

{
	"containerName": "cli"
}

### Execute Command - Unsupported containerName (POST, expected 400)
POST {{api}}/fabric/container/exec
Content-Type: application/json

{
	"containerName": "not-allowed-container",
	"command": "ls -la"
}

### Not Found Example (DELETE)
DELETE {{api}}/fabric/org/provision

