{
    "name": "Production Backend & Blockchain Server Simulation",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
    },
    "containerEnv": {
        "WORKSPACE_FOLDER": "${containerWorkspaceFolder}"
    },
    "postCreateCommand": "bash  .devcontainer/devPostCreate.sh && bash .devcontainer/fabricCAsetup.sh",
    "forwardPorts": [3000, 7050, 7051, 7053, 7054],
    "portsAttributes": {
        "3000": { "label": "Node.js API" },
        "7050": { "label": "Fabric Orderer" },
        "7051": { "label": "Fabric Peer" },
        "7053": { "label": "Peer Event Service" },
        "7054": { "label": "Fabric CA" }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "dbaeumer.vscode-eslint"
            ]
        }
    }
}